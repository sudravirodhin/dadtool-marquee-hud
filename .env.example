# Example Environment Settings for Marquee Mod Development
# Copy this file to .env and adjust the paths to match your local system.

# The root directory of the Marquee Mod source code (your working directory)
MARQUEE_WORKSPACE_DIR="C:/Path/To/dead_as_disco_hud_enhancements"

# Path to the game's UE4SS Mods directory where the Marquee scripts are deployed
MARQUEE_DEPLOY_DIR="C:/Program Files (x86)/Steam/steamapps/common/Dead as Disco/Pagoda/Binaries/Win64/ue4ss/Mods/Marquee/Scripts"

# Path to the sister dadtool project (for song importing / lyrics processing)
DADTOOL_DIR="C:/Path/To/dead_as_disco_song_import"

# Path to the Python executable used for packaging/releasing
PYTHON_PATH="C:/Users/YourUsername/AppData/Local/Programs/Python/PythonXX/python.exe"

# Path to the GitHub CLI executable (if not on PATH)
GH_CLI_PATH="C:/Program Files/GitHub CLI/gh.exe"
